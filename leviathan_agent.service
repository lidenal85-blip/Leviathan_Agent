[Unit]
Description=LEVIATHAN AGENT — Autonomous Gemini DevOps Agent
After=network.target

[Service]
WorkingDirectory=/opt/leviathan_agent
EnvironmentFile=/opt/leviathan_agent/.env
ExecStart=/opt/leviathan_agent/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8200
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
