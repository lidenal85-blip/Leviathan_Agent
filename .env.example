# ═══════════════════════════════════════════════
# LEVIATHAN AGENT — конфиг
# cp .env.example .env
# ═══════════════════════════════════════════════

# ── Gemini ключи (до 14 штук, индивидуально) ──────
# Получить: https://aistudio.google.com/apikey
GEMINI_K1=
GEMINI_K2=
GEMINI_K3=
GEMINI_K4=
GEMINI_K5=
GEMINI_K6=
# ... до GEMINI_K14

# ── Gemini модель ────────────────────────────────
GEMINI_MODEL=gemini-2.0-flash

# ── Telegram ───────────────────────────────────
TG_BOT_TOKEN=your_bot_token_here
TG_ADMIN_CHAT_ID=your_chat_id_here

# ── GitHub ─────────────────────────────────────
GITHUB_TOKEN=ghp_your_token_here
GITHUB_USERNAME=lidenal85-blip

# ── Сервер ─────────────────────────────────────
HOST=0.0.0.0
PORT=8200
SECRET_KEY=change_me_32_chars_min

# ── БД ─────────────────────────────────────────
DB_PATH=db/agent.db

# ── Безопасность ───────────────────────────────
# SAFE | NORMAL | FULL
DEFAULT_MODE=NORMAL

# ── Пути на сервере ────────────────────────────
WORKSPACE=/var/www
LEVIATHAN_ENGINE=/opt/leviathan_engine

# ── Лимиты ─────────────────────────────────────
MAX_ITERATIONS=50
TOOL_TIMEOUT_SEC=60
MAX_FILE_SIZE_KB=100

# ── Claude / Anthropic ─────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-sonnet-4-5
CLAUDE_THINKING_BUDGET=10000

# ── Model Router ────────────────────────────────────────
# AUTO | GEMINI_ONLY | CLAUDE_ONLY | GEMINI_THINK_CLAUDE | CLAUDE_THINK_GEMINI
MODEL_MODE=AUTO

# ── ArbitrCockpit ───────────────────────────────────────
ARBITR_URL=http://localhost:8090
