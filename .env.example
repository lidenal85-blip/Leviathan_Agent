# ═══════════════════════════════════════════════
# LEVIATHAN AGENT — конфиг
# cp .env.example .env
# ═══════════════════════════════════════════════

# ── Gemini ключи (через запятую, ротация) ──────
GEMINI_KEYS=key1,key2,key3

# ── Telegram ───────────────────────────────────
TG_BOT_TOKEN=your_bot_token_here
TG_ADMIN_CHAT_ID=your_chat_id_here

# ── GitHub ─────────────────────────────────────
GITHUB_TOKEN=ghp_your_token_here
GITHUB_USERNAME=lidenal85-blip

# ── Сервер ─────────────────────────────────────
HOST=0.0.0.0
PORT=8200
SECRET_KEY=change_me_32_chars_min

# ── БД ─────────────────────────────────────────
DB_PATH=db/agent.db

# ── Безопасность ───────────────────────────────
# SAFE | NORMAL | FULL
DEFAULT_MODE=NORMAL

# ── Пути на сервере ────────────────────────────
WORKSPACE=/var/www
LEVIATHAN_ENGINE=/opt/leviathan_engine

# ── Лимиты ─────────────────────────────────────
MAX_ITERATIONS=50
TOOL_TIMEOUT_SEC=60
MAX_FILE_SIZE_KB=100
